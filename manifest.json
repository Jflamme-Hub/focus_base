{
  "id": "/",
  "name": "Focus Base",
  "short_name": "Focus Base",
  "description": "An organization and routine-building app designed specifically for neurodivergent students to help stay focused, reduce overwhelm, and manage school work and daily habits with confidence.",
  "start_url": "./index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "background_color": "#ffffff",
  "theme_color": "#6750A4",
  "orientation": "portrait",
  "categories": [
    "productivity",
    "education",
    "lifestyle"
  ],
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "./app_icon_192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./app_icon_512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "./screenshot_narrow.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Focus Base Dashboard on Mobile"
    },
    {
      "src": "./screenshot_wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Focus Base Dashboard on Desktop"
    }
  ],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Add New Task",
      "short_name": "New Task",
      "description": "Quickly add a new task",
      "url": "/?action=add-task",
      "icons": [
        {
          "src": "./app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Start Focus Mode",
      "short_name": "Focus Mode",
      "description": "Start a new focus session",
      "url": "/?action=focus-mode",
      "icons": [
        {
          "src": "./app_icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  }
